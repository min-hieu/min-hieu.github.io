---
import Layout from "../../layouts/Layout.astro";
import { BlogMain } from '../../components/Blog.jsx';
import { Header, Division } from '../../components/Home.jsx';
import type { GetStaticPaths } from "../types/shared";
import type { Post } from "../types/post";
import { sortMDByDate, getUniqueTags, getTagColmap } from "../../utils";

const { page, uniqueTags, tagColmap } = Astro.props;

const meta = {
  title: "Posts",
  description: "A collection of posts by me for a starter Astro theme",
};

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const allPosts = await Astro.glob<Post>("./*.mdx");
  const allPostsByDate = sortMDByDate(allPosts);
  const uniqueTags = getUniqueTags(allPosts);
  const tagColmap  = getTagColmap(uniqueTags);
  return paginate(allPostsByDate, { props: { uniqueTags, tagColmap }, pageSize: 10 });
};

const paginationProps = {
  ...(page.url.prev && {
    prevUrl: {
      url: page.url.prev,
      text: `← Previous Posts`,
    },
  }),
  ...(page.url.next && {
    nextUrl: {
      url: page.url.next,
      text: `Next Posts →`,
    },
  }),
};

const pageMeta = page.data.map((p,idx) =>
  ({
    id: idx,
    title: p.frontmatter.title,
    date: p.frontmatter.date,
    tags: p.frontmatter.tags,
  })
)
---

<Layout meta={meta}>
  <BlogMain
    pageMeta={pageMeta}
    pageTag={uniqueTags}
    tagColmap={tagColmap}
    client:load
  />
</Layout>
