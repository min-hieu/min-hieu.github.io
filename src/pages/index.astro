---
import Layout from '../layouts/Layout.astro';
import {
  NewsCard,
  BibCard,
  NewsCon,
  HeaderS,
  ParaDiv,
  Section,
  Division,
  Socials,
  ScholarBtn,
} from '../components/Home.jsx';
import { Image, Picture } from '@astrojs/image/components';

const meta = {
  title: "min(Hieu)",
  description: "Welcome Home!",
}

import news_data from "../data/news.json";
import bib_data from "../data/mybibtex.json";
---

<Layout meta={meta}>
  <div class="indexMain">
    <div class="left">
      <div class="profileImage">
        <img
          src="/charlie.JPG" alt="me"
        />
      </div>
      <ParaDiv center={true}>
        <Socials/>
      </ParaDiv>
    </div>
    <div class="right">
      <ParaDiv>
          Hi! Thanks for being interested in my website. <br/>
          My name is <b>Hieu</b> and I am a currently a sophomore
          in the department of computer science and electrical
          engineering at KAIST, Korea. I am highly motivated about
          learning new things in the intersection of <b>computer graphics &
            machine learning</b>. I look foward to research opportunities
          in both industry and academia! <br/>
          In my free time I enjoy reading books
          , making sily programs, and most recently, baking! <br/>
      </ParaDiv>
      <br/>
      <HeaderS text="News"/>
      <Division />
      <NewsCon limit={5} size={news_data.news_data.length} client:visible>
        {
          news_data.news_data.map((news) => (
            <NewsCard date={news.date} title={news.title} client:visible/>
          ))
        }
      </NewsCon>
      <HeaderS text="Publications" />
      <Division />
      {
        bib_data.bibtex_data.map((bib) => (
          <BibCard
            title={bib.title}
            author={[bib.authorPre, bib.authorMe, bib.authorPost]}
            year={bib.year}
            journal={bib.journal}
            link={bib.link}
            client:visible
          />
        ))
      }
    </div>
  </div>
</Layout>

<style>
.indexMain {
  display: flex;
  flex-direction: row;
  padding-top: 5vmin;
}

.profileImage {
  display: flex;
  justify-content: center;
  align-item: center;
  padding: 4vmin;
}

img {
  width: 100%;
  border-radius: 0.6rem;
}

.left {
  width: 30%;
}

.right {
  width: 70%;
}

iframe {
  border-style: none;
  width: 100%;
  height: 40vh;
}

.demoEmbed {
  margin-bottom: 3vh;
}
</style>
